# ============================================================
# Wifix402 — Environment Variables
# ============================================================

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# 1Shot Relayer
ONE_SHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
ONE_SHOT_RELAYER_ADDRESS=0x...
ONE_SHOT_WEBHOOK_SECRET=your-webhook-signing-key

# Blockchain (Base Mainnet)
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Receiver wallet (collects WiFi payments)
RECEIVER_WALLET=0xYourReceiverWallet

# Webhook URL (set to your ngrok/tunnel URL for local dev)
WEBHOOK_URL=https://your-tunnel.ngrok.io/api/webhook/1shot

# Admin API auth
ADMIN_SECRET=change-me

# Hotspot config
HOTSPOT_WALLET=0xYourWalletAddress
HOTSPOT_NAME=Wifix402-Hotspot
HOTSPOT_LOCATION=Localhost
ROUTER_IP=192.168.1.1
ROUTER_MAC=aa:bb:cc:dd:ee:ff

# Firewall (macOS PF)
FIREWALL_TABLE_NAME=paid_users
FIREWALL_PFCTL_PATH=/usr/sbin/pfctl
